# Copy this file to `.env` next to docker-compose.yml on each server.
# `.env` is gitignored — never commit real values.
# docker-compose interpolates ${NAME} references from this file.

# Postmark Server API token (from the Postmark "Server" page > API Tokens)
POSTMARK_SERVER_TOKEN=

# Verified sender on your Postmark server (Sender Signatures must be set up + DKIM/SPF on the domain)
EMAIL_FROM_ADDRESS=noreply@sureprosoftware.com.au
EMAIL_FROM_NAME=FireStop Evac Tracker

# Public base URL used when building links inside email bodies.
# Prod:     https://firestopevacs.sureprosoftware.com.au
# Staging:  http://134.199.146.192:3001
APP_BASE_URL=https://firestopevacs.sureprosoftware.com.au
