@page "{shareCode}"
@model FireStopEvacTracker.Pages.JobApproveModel
@{
    ViewData["Title"] = "Approve Evacuation Diagram";
}

<div class="approval-page-container">
    <div class="approval-card">
        <div class="approval-header">
            <h1>Evacuation Diagram Approval</h1>
            <p>Please review and approve your evacuation diagram before final installation</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        @if (Model.IsApproved)
        {
            <div class="alert alert-success">
                <strong>✓ Approved!</strong> Your evacuation diagram has been approved and is ready for final print and
                installation.
            </div>
        }
        else if (Model.Job != null)
        {
            <div class="job-details">
                <div class="row">
                    <div class="col-md-6">
                        <strong>Client:</strong> @Model.Job.ClientName<br />
                        <strong>Site Address:</strong> @Model.Job.SiteAddress<br />
                        <strong>Job Name:</strong> @Model.Job.GetShortJobName()
                    </div>
                    <div class="col-md-6">
                        <strong>Approval Progress:</strong>
                        <div class="progress" style="height: 20px; margin-top: 5px;">
                            <div class="progress-bar" id="progressBar" style="width: @(Model.Approval?.ChecklistItemsCompleted * 25)%; transition: width 0.3s ease;"></div>
                        </div>
                        <small><span id="itemsCount">@(Model.Approval?.ChecklistItemsCompleted ?? 0)</span> of 4 items checked</small>
                    </div>
                </div>
            </div>

            @if (Model.Job.HasPdf)
            {
                <div class="pdf-section">
                    <p style="margin-bottom: 10px;">📄 Review & Markup Diagram:</p>

                    <div id="drawingContainer" style="position: relative; margin-bottom: 20px; border: 1px solid #ddd; border-radius: 8px; background: #f9f9f9; display: inline-block; width: 100%;" data-approval-id="@(Model.Approval?.Id ?? 0)">
                        <img id="diagramImage" src="@(Model.Job.DraftPdfPath?.Replace(".pdf", ".png"))" alt="Evacuation diagram preview" style="display: block; width: 100%; height: auto; border-radius: 8px;" />
                        <canvas id="drawingCanvas" style="position: absolute; top: 0; left: 0; cursor: crosshair; border-radius: 8px; display: none;"></canvas>
                    </div>

                    <div id="toolBar" style="display: flex; gap: 8px; margin-bottom: 15px; flex-wrap: wrap; align-items: center; margin-top: 15px;">
                        <button type="button" id="penTool" class="tool-btn tool-active" title="Pen" style="background: #4CAF50; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">✏️ Pen</button>
                        <div style="display: flex; gap: 4px; border-left: 1px solid #ccc; padding-left: 6px;">
                            <button type="button" class="color-btn" data-color="#FF0000" style="background: #FF0000; width: 24px; height: 24px; border: 2px solid #999; border-radius: 3px; cursor: pointer;" title="Red"></button>
                            <button type="button" class="color-btn" data-color="#0000FF" style="background: #0000FF; width: 24px; height: 24px; border: 2px solid #999; border-radius: 3px; cursor: pointer;" title="Blue"></button>
                            <button type="button" class="color-btn" data-color="#00AA00" style="background: #00AA00; width: 24px; height: 24px; border: 2px solid #999; border-radius: 3px; cursor: pointer;" title="Green"></button>
                        </div>
                        <button type="button" id="eraserTool" class="tool-btn" title="Eraser" style="background: #ff9800; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold; margin-left: 10px;">🗑️ Eraser</button>
                        <button type="button" id="undoBtn" class="tool-btn" title="Undo" style="background: #2196F3; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-left: 10px;">↶ Undo</button>
                        <button type="button" id="clearBtn" class="tool-btn" title="Clear All" style="background: #f44336; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-left: 4px;">🗑️ Clear</button>
                        <button type="button" id="saveAnnotationBtn" class="tool-btn" title="Save Markup" style="background: #9C27B0; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-left: auto;">💾 Save Markup</button>
                    </div>

                    <p style="margin-bottom: 10px; color: #666; font-size: 13px;">💡 Tip: Click Pen to enable drawing mode, then mark areas that need attention. Your markup will be saved with your approval.</p>
                    <p style="margin-bottom: 10px; color: #666; font-size: 13px;"><a href="@Model.Job.DraftPdfPath" target="_blank" class="pdf-link">Download original PDF</a></p>
                </div>
            }

            <form method="post">
                <div class="approver-info-section">
                    <label for="approverName">Your Name *</label>
                    <input type="text" id="approverName" name="ApproverName" class="form-control"
                           placeholder="Enter your full name" value="@Model.ApproverName" required />
                </div>

                <h3 class="checklist-title">Before we proceed to final print and installation, please complete the checklist
                    below:</h3>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item1" name="LayoutAccuracyApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.LayoutAccuracyApproved == true ? "checked" : "") />
                        </div>
                        <label for="item1" class="checkbox-label">
                            <strong>1. Layout Accuracy</strong>
                            <span>Please confirm the building layout shown matches your current premises, including rooms, doors, walls.</span>
                        </label>
                    </div>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item2" name="FireEquipmentLocationsApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.FireEquipmentLocationsApproved == true ? "checked" : "") />
                        </div>
                        <label for="item2" class="checkbox-label">
                            <strong>2. Fire Equipment Locations</strong>
                            <span>Please confirm all fire safety equipment is shown in the correct location, including:</span>
                            <ul>
                                <li>Fire extinguishers</li>
                                <li>Hose reels</li>
                                <li>Fire blankets</li>
                                <li>First aid kits</li>
                                <li>Exit points</li>
                                <li>Any other safety equipment</li>
                            </ul>
                        </label>
                    </div>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item3" name="YouAreHereApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.YouAreHereApproved == true ? "checked" : "") />
                        </div>
                        <label for="item3" class="checkbox-label">
                            <strong>3. "You Are Here" Position</strong>
                            <span>Please confirm the "You Are Here" marker is in the correct location.</span>
                        </label>
                    </div>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item4" name="DiagramMountingLocationApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.DiagramMountingLocationApproved == true ? "checked" : "") />
                        </div>
                        <label for="item4" class="checkbox-label">
                            <strong>4. Diagram Mounting Location</strong>
                            <span>Please confirm where the diagram will be installed:</span>
                            <ul>
                                <li>Between 1200mm – 1600mm from floor level</li>
                                <li>Clearly visible to occupants</li>
                                <li>Not mounted on glass</li>
                                <li>Suitable wall/surface for screw fixing</li>
                            </ul>
                            <div style="margin-top: 15px; text-align: center;">
                                <img src="/img/mounting-height-compliance.png" alt="Evacuation Diagram Mounting Height for Customer Visibility and Compliance" style="max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />
                            </div>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-approve">
                        ✓ Submit Approval
                    </button>
                </form>

                <div class="changes-section" style="margin-top: 40px; padding-top: 30px; border-top: 2px solid #eee;">
                    <h3 style="margin-bottom: 20px;">5. Changes Required (Optional)</h3>
                    <p style="color: #666; font-size: 14px; margin-bottom: 15px;">Submit any corrections or feedback about your evacuation diagram. These will be saved as notes and visible to the FireStop team.</p>
                    <form method="post" asp-page-handler="Changes">
                        <div style="display: none;">
                            <input type="text" name="ApproverName" value="@Model.ApproverName" />
                        </div>
                        <textarea id="changes" name="ChangesRequired" rows="4"
                                  placeholder="If any corrections are needed, please describe them here..."
                                  style="margin-bottom: 15px;">@Model.Approval?.ChangesRequired</textarea>
                        <button type="submit" class="btn btn-secondary" style="background: #667eea; color: white;">
                            📝 Submit Changes as Note
                        </button>
                    </form>
                </div>
            }
        else
            {
                <div class="alert alert-danger">
                    Invalid or expired approval link. Please contact your diagram provider.
                </div>
            }
        </div>
    </div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>

<script>
    let fabricCanvas = null;
    let drawingHistory = [];
    let currentPenColor = '#FF0000';
    let isDrawingEnabled = false;

    // Checklist progress
    document.querySelectorAll('.approval-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', updateProgress);
    });

    function updateProgress() {
        const checkboxes = document.querySelectorAll('.approval-checkbox');
        const checked = Array.from(checkboxes).filter(cb => cb.checked).length;
        const percentage = (checked / 4) * 100;
        document.getElementById('progressBar').style.width = percentage + '%';
        document.getElementById('itemsCount').textContent = checked;
    }

    // Drawing canvas initialization
    function initializeDrawingCanvas() {
        const img = document.getElementById('diagramImage');
        const drawingCanvas = document.getElementById('drawingCanvas');
        if (!img || !drawingCanvas) return;

        const loadCanvas = () => {
            drawingCanvas.width = img.offsetWidth;
            drawingCanvas.height = img.offsetHeight;
            drawingCanvas.style.width = img.offsetWidth + 'px';
            drawingCanvas.style.height = img.offsetHeight + 'px';
            drawingCanvas.style.display = 'block';

            fabricCanvas = new fabric.Canvas('drawingCanvas', {
                width: img.offsetWidth,
                height: img.offsetHeight,
                isDrawingMode: false
            });

            drawingHistory = [JSON.stringify(fabricCanvas)];
        };

        img.complete ? loadCanvas() : (img.onload = loadCanvas);
    }

    function enableDrawing(mode = 'pen') {
        if (!fabricCanvas) return;
        isDrawingEnabled = true;
        fabricCanvas.isDrawingMode = true;

        if (mode === 'pen') {
            fabricCanvas.freeDrawingBrush = new fabric.PencilBrush(fabricCanvas);
            fabricCanvas.freeDrawingBrush.color = currentPenColor;
            fabricCanvas.freeDrawingBrush.width = 3;
        } else {
            fabricCanvas.freeDrawingBrush = new fabric.EraserBrush(fabricCanvas);
            fabricCanvas.freeDrawingBrush.width = 15;
        }
        fabricCanvas.on('object:added', () => drawingHistory.push(JSON.stringify(fabricCanvas)));
        updateToolButtons(mode);
    }

    function undo() {
        if (!fabricCanvas || drawingHistory.length <= 1) return;
        drawingHistory.pop();
        fabricCanvas.loadFromJSON(drawingHistory[drawingHistory.length - 1], () => fabricCanvas.renderAll());
    }

    function clearCanvas() {
        if (!fabricCanvas) return;
        fabricCanvas.clear();
        drawingHistory = [JSON.stringify(fabricCanvas)];
    }

    // Tool handlers
    document.getElementById('penTool')?.addEventListener('click', e => { e.preventDefault(); enableDrawing('pen'); });
    document.getElementById('eraserTool')?.addEventListener('click', e => { e.preventDefault(); enableDrawing('eraser'); });
    document.querySelectorAll('.color-btn').forEach(btn => btn.addEventListener('click', e => {
        e.preventDefault();
        currentPenColor = btn.dataset.color;
        if (fabricCanvas && isDrawingEnabled) fabricCanvas.freeDrawingBrush.color = currentPenColor;
    }));
    document.getElementById('undoBtn')?.addEventListener('click', e => { e.preventDefault(); undo(); });
    document.getElementById('clearBtn')?.addEventListener('click', e => { e.preventDefault(); if (confirm('Clear all?')) clearCanvas(); });

    document.getElementById('saveAnnotationBtn')?.addEventListener('click', async function(e) {
        e.preventDefault();
        if (!fabricCanvas || !fabricCanvas._objects.length) { alert('No annotations to save!'); return; }

        const container = document.getElementById('drawingContainer');
        const approvalId = container?.dataset.approvalId;
        if (!approvalId || approvalId === '0') { alert('Please fill in your name first.'); return; }

        try {
            const res = await fetch('/api/jobs/save-annotation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    jobApprovalId: parseInt(approvalId),
                    canvasDataUrl: fabricCanvas.toDataURL({ format: 'png', quality: 0.8 })
                })
            });
            alert(res.ok ? '✓ Markup saved!' : 'Error saving markup');
        } catch(err) { alert('Error: ' + err.message); }
    });

    function updateToolButtons(tool) {
        document.getElementById('penTool')?.classList.toggle('tool-active', tool === 'pen');
        document.getElementById('eraserTool')?.classList.toggle('tool-active', tool === 'eraser');
    }
    window.addEventListener('load', initializeDrawingCanvas);
</script>
