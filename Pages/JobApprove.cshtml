@page "{shareCode}"
@model FireStopEvacTracker.Pages.JobApproveModel
@{
    ViewData["Title"] = "Approve Evacuation Diagram";
}

<div class="approval-page-container">
    <div class="approval-card">
        <div class="approval-header">
            <h1>Evacuation Diagram Approval</h1>
            <p>Please review and approve your evacuation diagram before final installation</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        @if (Model.IsApproved)
        {
            <div class="alert alert-success">
                <strong>✓ Approved!</strong> Your evacuation diagram has been approved and is ready for final print and
                installation.
            </div>
        }
        else if (Model.Job != null)
        {
            <div class="job-details">
                <div class="row">
                    <div class="col-md-6">
                        <strong>Client:</strong> @Model.Job.ClientName<br />
                        <strong>Site Address:</strong> @Model.Job.SiteAddress<br />
                        <strong>Job Name:</strong> @Model.Job.GetShortJobName()
                    </div>
                    <div class="col-md-6">
                        <strong>Approval Progress:</strong>
                        <div class="progress" style="height: 20px; margin-top: 5px;">
                            <div class="progress-bar" id="progressBar" style="width: @(Model.Approval?.ChecklistItemsCompleted * 25)%; transition: width 0.3s ease;"></div>
                        </div>
                        <small><span id="itemsCount">@(Model.Approval?.ChecklistItemsCompleted ?? 0)</span> of 4 items checked</small>
                    </div>
                </div>
            </div>

            @if (Model.Job.HasPdf)
            {
                <div class="pdf-section">
                    <p style="margin-bottom: 10px;">📄 Review & Markup Diagram:</p>

                    <div id="drawingContainer" style="position: relative; margin-bottom: 20px; border: 1px solid #ddd; border-radius: 8px; background: #f9f9f9; width: 100%; overflow: hidden; max-height: 600px; user-select: none; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none;" data-approval-id="@(Model.Approval?.Id ?? 0)">
                        <img id="diagramImage" src="@(Model.Job.DraftPdfPath?.Replace(".pdf", ".png"))" alt="Evacuation diagram preview" draggable="false" style="width: 100%; height: auto; border-radius: 8px; user-select: none; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none; display: block; transition: transform 0.3s ease;" />
                    </div>

                    <div id="toolBar" style="display: flex; gap: 8px; margin-bottom: 15px; flex-wrap: wrap; align-items: center; margin-top: 15px;">
                        <button type="button" id="zoomInBtn" class="tool-btn" title="Zoom In" style="background: #FF9800; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">🔍+ Zoom In</button>
                        <button type="button" id="zoomOutBtn" class="tool-btn" title="Zoom Out" style="background: #FF9800; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">🔍- Zoom Out</button>
                        <button type="button" id="zoomResetBtn" class="tool-btn" title="Reset Zoom" style="background: #FF9800; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">↺ Reset</button>
                        <div style="border-left: 1px solid #ccc; height: 24px; margin: 0 4px;"></div>
                        <button type="button" id="penTool" class="tool-btn tool-active" title="Draw" style="background: #4CAF50; color: white; border: 2px solid #2d7a2d; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">✏️ Draw</button>
                        <button type="button" id="eraserTool" class="tool-btn" title="Erase" style="background: #FF5722; color: white; border: 2px solid transparent; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">🧹 Erase</button>
                        <div style="display: flex; gap: 4px; border-left: 1px solid #ccc; padding-left: 6px;">
                            <button type="button" class="color-btn color-btn-selected" data-color="#FF0000" style="background: #FF0000; width: 24px; height: 24px; border: 3px solid #333; border-radius: 3px; cursor: pointer;" title="Red"></button>
                            <button type="button" class="color-btn" data-color="#0000FF" style="background: #0000FF; width: 24px; height: 24px; border: 2px solid #999; border-radius: 3px; cursor: pointer;" title="Blue"></button>
                            <button type="button" class="color-btn" data-color="#00AA00" style="background: #00AA00; width: 24px; height: 24px; border: 2px solid #999; border-radius: 3px; cursor: pointer;" title="Green"></button>
                        </div>
                        <button type="button" id="undoBtn" class="tool-btn" title="Undo" style="background: #2196F3; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-left: 10px;">↶ Undo</button>
                        <button type="button" id="clearBtn" class="tool-btn" title="Clear All" style="background: #f44336; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-left: 4px;">🗑️ Clear</button>
                        <button type="button" id="saveAnnotationBtn" class="tool-btn" title="Save Markup" style="background: #9C27B0; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-left: auto;">💾 Save Markup</button>
                    </div>

                    <p style="margin-bottom: 10px; color: #666; font-size: 13px;">💡 Tip: Click Pen to enable drawing mode, then mark areas that need attention. Your markup will be saved with your approval.</p>
                    <p style="margin-bottom: 10px; color: #666; font-size: 13px;"><a href="@Model.Job.DraftPdfPath" target="_blank" class="pdf-link">Download original PDF</a></p>
                </div>
            }

            <form method="post">
                <div class="approver-info-section">
                    <label for="approverName">Your Name *</label>
                    <input type="text" id="approverName" name="ApproverName" class="form-control"
                           placeholder="Enter your full name" value="@Model.ApproverName" required />
                </div>

                <h3 class="checklist-title">Before we proceed to final print and installation, please complete the checklist
                    below:</h3>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item1" name="LayoutAccuracyApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.LayoutAccuracyApproved == true ? "checked" : "") />
                        </div>
                        <label for="item1" class="checkbox-label">
                            <strong>1. Layout Accuracy</strong>
                            <span>Please confirm the building layout shown matches your current premises, including rooms, doors, walls.</span>
                        </label>
                    </div>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item2" name="FireEquipmentLocationsApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.FireEquipmentLocationsApproved == true ? "checked" : "") />
                        </div>
                        <label for="item2" class="checkbox-label">
                            <strong>2. Fire Equipment Locations</strong>
                            <span>Please confirm all fire safety equipment is shown in the correct location, including:</span>
                            <ul>
                                <li>Fire extinguishers</li>
                                <li>Hose reels</li>
                                <li>Fire blankets</li>
                                <li>First aid kits</li>
                                <li>Exit points</li>
                                <li>Any other safety equipment</li>
                            </ul>
                        </label>
                    </div>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item3" name="YouAreHereApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.YouAreHereApproved == true ? "checked" : "") />
                        </div>
                        <label for="item3" class="checkbox-label">
                            <strong>3. "You Are Here" Position</strong>
                            <span>Please confirm the "You Are Here" marker is in the correct location.</span>
                        </label>
                    </div>

                    <div class="checklist-item">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="item4" name="DiagramMountingLocationApproved" value="true" class="approval-checkbox"
                            @(Model.Approval?.DiagramMountingLocationApproved == true ? "checked" : "") />
                        </div>
                        <label for="item4" class="checkbox-label">
                            <strong>4. Diagram Mounting Location</strong>
                            <span>Please confirm where the diagram will be installed:</span>
                            <ul>
                                <li>Between 1200mm – 1600mm from floor level</li>
                                <li>Clearly visible to occupants</li>
                                <li>Not mounted on glass</li>
                                <li>Suitable wall/surface for screw fixing</li>
                            </ul>
                            <div style="margin-top: 15px; text-align: center;">
                                <img src="/img/mounting-height-compliance.png" alt="Evacuation Diagram Mounting Height for Customer Visibility and Compliance" style="max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />
                            </div>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-approve">
                        ✓ Submit Approval
                    </button>
                </form>

                <div class="changes-section" style="margin-top: 40px; padding-top: 30px; border-top: 2px solid #eee;">
                    <h3 style="margin-bottom: 20px;">5. Changes Required (Optional)</h3>
                    <p style="color: #666; font-size: 14px; margin-bottom: 15px;">Submit any corrections or feedback about your evacuation diagram. These will be saved as notes and visible to the FireStop team.</p>
                    <form method="post" asp-page-handler="Changes">
                        <div style="display: none;">
                            <input type="text" name="ApproverName" value="@Model.ApproverName" />
                        </div>
                        <textarea id="changes" name="ChangesRequired" rows="4"
                                  placeholder="If any corrections are needed, please describe them here..."
                                  style="margin-bottom: 15px;">@Model.Approval?.ChangesRequired</textarea>
                        <button type="submit" class="btn btn-secondary" style="background: #667eea; color: white;">
                            📝 Submit Changes as Note
                        </button>
                    </form>
                </div>
            }
        else
            {
                <div class="alert alert-danger">
                    Invalid or expired approval link. Please contact your diagram provider.
                </div>
            }
        </div>
    </div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/annotorious/3.0.0/annotorious.min.js"></script>

<script>
    let anno = null;
    let currentColor = '#FF0000';
    let currentTool = 'pen';
    let zoomLevel = 1;
    const img = document.getElementById('diagramImage');
    const container = document.getElementById('drawingContainer');

    // Prevent selection and drag on image (don't prevent mousedown - Annotorious needs it)
    img.addEventListener('dragstart', (e) => e.preventDefault());
    img.addEventListener('selectstart', (e) => e.preventDefault());
    container.addEventListener('dragstart', (e) => e.preventDefault());
    container.addEventListener('selectstart', (e) => e.preventDefault());

    // Initialize Annotorious
    window.addEventListener('load', () => {
        anno = Annotorious.init({
            image: img,
            tools: ['freehand'],
            drawingEnabled: true,
            disableEditor: false,
            autoSave: false
        });

        // Set freehand as active tool
        if (anno) {
            anno.setDrawingTool('freehand');
        }
    });

    // Zoom functionality
    function updateZoom() {
        img.style.transform = `scale(${zoomLevel})`;
        img.style.transformOrigin = 'top center';
    }

    document.getElementById('zoomInBtn')?.addEventListener('click', (e) => {
        e.preventDefault();
        zoomLevel = Math.min(zoomLevel + 0.2, 3);
        updateZoom();
    });

    document.getElementById('zoomOutBtn')?.addEventListener('click', (e) => {
        e.preventDefault();
        zoomLevel = Math.max(zoomLevel - 0.2, 1);
        updateZoom();
    });

    document.getElementById('zoomResetBtn')?.addEventListener('click', (e) => {
        e.preventDefault();
        zoomLevel = 1;
        updateZoom();
    });

    // Scroll wheel zoom
    container.addEventListener('wheel', (e) => {
        if (e.ctrlKey) {
            e.preventDefault();
            if (e.deltaY < 0) {
                zoomLevel = Math.min(zoomLevel + 0.1, 3);
            } else {
                zoomLevel = Math.max(zoomLevel - 0.1, 1);
            }
            updateZoom();
        }
    });

    // Pan when zoomed
    let isPanning = false;
    let panStart = { x: 0, y: 0 };

    container.addEventListener('mousedown', (e) => {
        if (zoomLevel > 1 && e.button === 2) {
            isPanning = true;
            panStart = { x: e.clientX, y: e.clientY };
        }
    });

    container.addEventListener('mousemove', (e) => {
        if (isPanning) {
            const dx = (e.clientX - panStart.x) / (zoomLevel * 100);
            const dy = (e.clientY - panStart.y) / (zoomLevel * 100);
            img.style.marginLeft = (dx) + 'px';
            img.style.marginTop = (dy) + 'px';
        }
    });

    container.addEventListener('mouseup', () => {
        isPanning = false;
    });

    // Color buttons
    document.querySelectorAll('.color-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            currentColor = btn.dataset.color;

            // Remove selected state from all color buttons
            document.querySelectorAll('.color-btn').forEach(b => {
                b.style.border = '2px solid #999';
            });

            // Add selected state to clicked button
            btn.style.border = '3px solid #333';
            btn.classList.add('color-btn-selected');

            if (anno) {
                anno.setAuthInfo({
                    user: 'reviewer'
                });
            }
        });
    });

    // Draw tool (Pen)
    document.getElementById('penTool')?.addEventListener('click', (e) => {
        e.preventDefault();
        currentTool = 'pen';

        if (anno) {
            anno.setDrawingTool('freehand');
        }

        // Update tool button visuals
        document.getElementById('penTool').style.borderColor = '#2d7a2d';
        document.getElementById('eraserTool').style.borderColor = 'transparent';
    });

    // Eraser tool - removes annotations on click
    document.getElementById('eraserTool')?.addEventListener('click', (e) => {
        e.preventDefault();
        currentTool = 'eraser';

        // Disable drawing mode when eraser is active
        if (anno) {
            anno.setDrawingTool(null);
        }

        // Update tool button visuals
        document.getElementById('penTool').style.borderColor = 'transparent';
        document.getElementById('eraserTool').style.borderColor = '#333';
    });

    // When eraser is active, clicking removes the last annotation
    img.addEventListener('click', (e) => {
        if (currentTool === 'eraser' && anno) {
            const annotations = anno.getAnnotations();
            if (annotations.length > 0) {
                anno.removeAnnotation(annotations[annotations.length - 1]);
            }
        }
    }, true);

    // Undo button
    document.getElementById('undoBtn')?.addEventListener('click', (e) => {
        e.preventDefault();
        if (anno) {
            const annotations = anno.getAnnotations();
            if (annotations.length > 0) {
                anno.removeAnnotation(annotations[annotations.length - 1]);
            }
        }
    });

    // Clear button
    document.getElementById('clearBtn')?.addEventListener('click', (e) => {
        e.preventDefault();
        if (confirm('Clear all drawings?') && anno) {
            anno.getAnnotations().forEach(a => anno.removeAnnotation(a));
        }
    });

    // Save button
    document.getElementById('saveAnnotationBtn')?.addEventListener('click', async (e) => {
        e.preventDefault();
        const approvalId = container?.dataset.approvalId;

        if (!approvalId || approvalId === '0') {
            alert('Approval ID not found');
            return;
        }

        try {
            // Capture image with annotations using html2canvas
            const script = document.createElement('script');
            script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
            script.onload = async () => {
                const canvas = await html2canvas(img);
                const res = await fetch('/api/jobs/save-annotation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        jobApprovalId: parseInt(approvalId),
                        canvasDataUrl: canvas.toDataURL('image/png')
                    })
                });
                alert(res.ok ? '✓ Markup saved!' : 'Error saving markup');
            };
            document.head.appendChild(script);
        } catch(err) {
            alert('Error: ' + err.message);
        }
    });

    // Checklist progress
    document.querySelectorAll('.approval-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', updateProgress);
    });

    function updateProgress() {
        const checkboxes = document.querySelectorAll('.approval-checkbox');
        const checked = Array.from(checkboxes).filter(cb => cb.checked).length;
        const percentage = (checked / 4) * 100;
        document.getElementById('progressBar').style.width = percentage + '%';
        document.getElementById('itemsCount').textContent = checked;
    }
</script>
