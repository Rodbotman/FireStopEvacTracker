@page
@model FireStopEvacTracker.Pages.Jobs.IndexModel
@{
    ViewData["Title"] = "Jobs";
}

<div class="page-header">
    <div>
        <h1>Evacuation Diagram Jobs</h1>
        <p>Track client jobs, draft PDFs, and review status.</p>
    </div>
    <a class="primary-button" href="/Jobs/Create">+ New Job</a>
</div>

<form method="get" class="filter-card">
    <input type="text" name="Search" value="@Model.Search" placeholder="Search client, address or job name" />
    <select name="Status">
        <option value="">All statuses</option>
        @foreach (var status in JobStatus.All)
        {
            <option value="@status" selected="@(Model.Status == status)">@status</option>
        }
    </select>
    <button type="submit">Search</button>
</form>

<table class="jobs-table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Job Name</th>
            <th>Client</th>
            <th>Address</th>
            <th>Status</th>
            <th>PDF</th>
            <th>Billed</th>
            @if (Model.IsAdmin)
            {
                <th>Billed Amount</th>
            }
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model.Jobs)
        {
            <tr>
                <td>@job.DateStarted.ToString("dd/MM/yyyy")</td>
                <td class="job-name">@job.GetShortJobName()</td>
                <td>@job.ClientName</td>
                <td>@job.SiteAddress</td>
                <td><span class="status-pill status-@job.Status.ToLower().Replace(" ", "-")">@job.Status</span></td>
                <td>
                    @if (job.HasPdf)
                    {
                        <span class="yes">Yes</span>
                    }
                    else
                    {
                        <span class="no">No</span>
                    }
                </td>
                <td>
                    <button class="billed-toggle @(job.IsBilled ? "billed-active" : "")" 
                            data-job-id="@job.Id" 
                            title="@(job.IsBilled ? "Unbilled" : "Mark as billed to Firestop this week")">
                        $
                    </button>
                </td>
                @if (Model.IsAdmin)
                {
                    <td>
                        <div class="billing-amount-cell" data-job-id="@job.Id" data-amount="@job.BilledAmount">
                            <span class="billing-display">$@job.BilledAmount.ToString("F2")</span>
                            <button class="edit-icon" title="Edit billing amount" aria-label="Edit billing amount">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </button>
                            <input type="number" class="billed-amount-input" 
                                   data-job-id="@job.Id" 
                                   value="@job.BilledAmount" 
                                   min="0" step="0.01" 
                                   placeholder="$0.00" 
                                   style="display: none;" 
                                   title="Enter billing amount for this job" />
                        </div>
                    </td>
                }
                <td><a class="small-button" href="/Jobs/Details/@job.Id">Open</a></td>
            </tr>
        }
    </tbody>
    @if (Model.IsAdmin)
    {
        <tfoot>
            <tr class="tally-row">
                <td colspan="7" style="text-align: right; font-weight: bold; padding-right: 20px;">Total Billed:</td>
                <td><strong id="billing-tally">$0.00</strong></td>
                <td></td>
            </tr>
        </tfoot>
    }
</table>

<script>
function updateBillingTally() {
    const inputs = document.querySelectorAll('.billed-amount-input');
    let total = 0;
    inputs.forEach(input => {
        const value = parseFloat(input.value) || 0;
        total += value;
    });
    const tally = document.getElementById('billing-tally');
    if (tally) {
        tally.textContent = '$' + total.toFixed(2);
    }
}

document.querySelectorAll('.billed-toggle').forEach(button => {
    button.addEventListener('click', async (e) => {
        e.preventDefault();
        const jobId = button.dataset.jobId;
        
        try {
            const response = await fetch(`/api/jobs/toggle-billed/${jobId}`, {
                method: 'POST'
            });
            
            if (response.ok) {
                const result = await response.json();
                button.classList.toggle('billed-active', result.isBilled);
                button.title = result.isBilled ? 'Unbilled' : 'Mark as billed to Firestop this week';
            } else {
                alert('Error updating billed status');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error updating billed status');
        }
    });
});

@if (Model.IsAdmin)
{
    <text>
// Handle billing amount edit icon clicks
document.querySelectorAll('.edit-icon').forEach(button => {
    button.addEventListener('click', (e) => {
        e.preventDefault();
        const cell = button.closest('.billing-amount-cell');
        const display = cell.querySelector('.billing-display');
        const input = cell.querySelector('.billed-amount-input');
        
        // Switch to edit mode
        display.style.display = 'none';
        button.style.display = 'none';
        input.style.display = 'inline-block';
        input.focus();
        input.select();
    });
});

// Handle billing amount input save and cancel
document.querySelectorAll('.billed-amount-input').forEach(input => {
    async function saveAmount() {
        const jobId = input.dataset.jobId;
        const amount = parseFloat(input.value) || 0;
        const cell = input.closest('.billing-amount-cell');
        const display = cell.querySelector('.billing-display');
        const editBtn = cell.querySelector('.edit-icon');

        try {
            const response = await fetch(`/api/jobs/update-billed-amount/${jobId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ amount: amount })
            });
            
            if (response.ok) {
                const result = await response.json();
                // Update display with new amount
                display.textContent = '$' + result.billedAmount.toFixed(2);
                cell.dataset.amount = result.billedAmount;
                updateBillingTally();
                
                // Switch back to display mode
                input.style.display = 'none';
                display.style.display = 'inline';
                editBtn.style.display = 'inline-block';
            } else {
                const error = await response.json();
                alert(error.error || 'Error updating billing amount');
                input.value = cell.dataset.amount;
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error updating billing amount');
            input.value = cell.dataset.amount;
        }
    }

    function cancelEdit() {
        const cell = input.closest('.billing-amount-cell');
        const display = cell.querySelector('.billing-display');
        const editBtn = cell.querySelector('.edit-icon');
        
        input.value = cell.dataset.amount;
        input.style.display = 'none';
        display.style.display = 'inline';
        editBtn.style.display = 'inline-block';
    }

    input.addEventListener('blur', saveAmount);
    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            saveAmount();
        } else if (e.key === 'Escape') {
            cancelEdit();
        }
    });
});

// Initialize tally on page load
updateBillingTally();
    </text>
}
</script>
