@page "{id:int}"
@model FireStopEvacTracker.Pages.Jobs.DetailsModel
@{
    ViewData["Title"] = "Job Details";
}

@if (Model.Job is not null)
{
    <div class="page-header">
        <div>
            <h1>@Model.Job.GetShortJobName()</h1>
            <p>@Model.Job.ClientName — @Model.Job.SiteAddress</p>
        </div>
        <a class="secondary-button" href="/Jobs">Back to Jobs</a>
    </div>

    <div class="details-grid">
        <section class="details-card">
            <h2>Job Details</h2>
            <dl>
                <dt>Date Started</dt>
                <dd>@Model.Job.DateStarted.ToString("dd/MM/yyyy")</dd>

                <dt>Client</dt>
                <dd>@Model.Job.ClientName</dd>

                <dt>Address</dt>
                <dd>@Model.Job.SiteAddress</dd>

                <dt>Status</dt>
                <dd>
                    <span class="status-pill status-@Model.Job.Status.ToLower().Replace(" ", "-")">@Model.Job.Status</span>
                    @if (Model.Job.StatusUpdatedAt.HasValue)
                    {
                        <span class="status-timestamp">Updated: @Model.Job.StatusUpdatedAt.Value.ToSydneyString()</span>
                    }
                </dd>

                <dt>Notes</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Job.Notes) ? "-" : Model.Job.Notes)</dd>
            </dl>
        </section>

        <section class="details-card">
            <h2>Draft PDF</h2>

            @if (Model.Job.HasPdf)
            {
                <p><strong>@Model.Job.DraftPdfFileName</strong></p>
                
                <!-- PDF Preview -->
                <div class="pdf-preview-container" id="pdfPreviewContainer">
                    <canvas id="pdfCanvas" style="width: 100%; border: 1px solid #ddd; border-radius: 4px;"></canvas>
                    <div id="pdfLoading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #999; font-size: 14px; background: white; padding: 20px; border-radius: 4px;">Loading PDF...</div>
                </div>
                
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <a class="primary-button" href="@Model.Job.DraftPdfPath" target="_blank" style="display: flex; align-items: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            View PDF
                        </a>
                        
                        @{
                            string emailSubject = $"Evacuation Drawings Ready for Review - {Model.Job.JobName}";
                            string emailBody = $"Hi {Model.Job.ClientName},%0A%0AThe attached evacuation diagram drawings are ready for your review.%0A%0APlease find the PDF attached.%0A%0AJob: {Model.Job.JobName}%0AClient: {Model.Job.ClientName}%0AAddress: {Model.Job.SiteAddress}%0A%0APlease let me know if you have any questions or require any modifications.%0A%0ABest regards,";
                            string mailtoLink = $"mailto:?subject={Uri.EscapeDataString(emailSubject)}&body={emailBody}";
                        }
                        <a href="@mailtoLink" class="primary-button" title="Open in email client (attach PDF manually)" style="display: flex; align-items: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg>
                            Email Client
                        </a>
                        <a href="@Model.Job.DraftPdfPath" download="@Model.Job.DraftPdfFileName" class="secondary-button" title="Download PDF for email attachment" style="display: flex; align-items: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            Download
                        </a>
                    </div>
                }
            else
                {
                    <p>No draft PDF attached.</p>
                }

                <form method="post" enctype="multipart/form-data" asp-page-handler="ReplacePdf" class="mini-form">
                    <input type="file" asp-for="NewDraftPdf" accept="application/pdf" />
                    <button type="submit">Attach / Replace PDF</button>
                </form>

                @if (Model.Job.HasPdf)
                {
                    <form method="post" asp-page-handler="RemovePdf" class="mini-form">
                        <button type="submit" class="danger-button">Remove PDF</button>
                    </form>
                }
            </section>

            <section class="details-card">
                <h2>👥 Client Approval</h2>
                
                @if (string.IsNullOrEmpty(Model.Job.ShareCode))
                {
                    <p>Generate a shareable link to send to your client for approval.</p>
                    <form method="post" asp-page-handler="GenerateShareCode" class="mini-form">
                        <button type="submit" class="primary-button" style="display: flex; align-items: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                            Generate Share Link
                        </button>
                    </form>
                }
                else
                {
                    <div style="background: #f0f7ff; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                        <strong>Share Link:</strong><br />
                        <div style="display: flex; gap: 8px; align-items: stretch; margin-top: 10px;">
                            <input type="text" id="shareLink" readonly style="flex: 1; padding: 10px; background: white; border: 1px solid #ddd; border-radius: 4px; font-family: monospace; font-size: 13px;" value="@Html.Raw($"{Request.Scheme}://{Request.Host}/JobApprove/{Model.Job.ShareCode}")" />
                            <button type="button" id="copyBtn" onclick="copyShareLink()" title="Copy link to clipboard" style="background: #f0f0f0; border: 1px solid #ddd; color: #333; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-size: 18px; white-space: nowrap; flex-shrink: 0; min-width: 44px; display: flex; align-items: center; justify-content: center;">
                                <svg id="copyIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: block;">
                                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
                                </svg>
                                <span id="copyText" style="display: none; margin-left: 6px;">✓</span>
                            </button>
                        </div>
                    </div>

                    <script>
                        function copyShareLink() {
                            const shareLink = document.getElementById('shareLink');
                            const btn = document.getElementById('copyBtn');
                            const copyIcon = document.getElementById('copyIcon');
                            const copyText = document.getElementById('copyText');
                            let success = false;
                            
                            // Try modern Clipboard API first (HTTPS only)
                            if (navigator.clipboard && window.isSecureContext) {
                                navigator.clipboard.writeText(shareLink.value).then(() => {
                                    showSuccess(btn, copyIcon, copyText);
                                }).catch(err => {
                                    console.error('Clipboard API failed:', err);
                                    fallbackCopy(shareLink, btn, copyIcon, copyText);
                                });
                            } else {
                                // Fallback for HTTP connections
                                fallbackCopy(shareLink, btn, copyIcon, copyText);
                            }
                            
                            function fallbackCopy(element, button, icon, text) {
                                try {
                                    // Select the text
                                    element.select();
                                    element.setSelectionRange(0, 99999); // For mobile
                                    
                                    // Copy using execCommand
                                    const successful = document.execCommand('copy');
                                    if (successful) {
                                        showSuccess(button, icon, text);
                                    } else {
                                        alert('Please manually copy the link');
                                    }
                                } catch (err) {
                                    console.error('Fallback copy failed:', err);
                                    alert('Unable to copy. Please manually select and copy the link.');
                                }
                            }
                            
                            function showSuccess(button, icon, text) {
                                icon.style.display = 'none';
                                text.style.display = 'inline';
                                button.style.background = '#d4edda';
                                button.style.borderColor = '#28a745';
                                button.style.color = '#155724';
                                
                                setTimeout(() => {
                                    icon.style.display = 'block';
                                    text.style.display = 'none';
                                    button.style.background = '#f0f0f0';
                                    button.style.borderColor = '#ddd';
                                    button.style.color = '#333';
                                }, 1500);
                            }
                        }
                    </script>

                    @if (Model.Approval != null)
                    {
                        <div style="background: #f5f5f5; padding: 15px; border-radius: 8px;">
                            <strong>Approval Status:</strong><br />
                            <div style="margin-top: 10px;">
                                @if (Model.Approval.IsApproved)
                                {
                                    <span style="color: #28a745; font-weight: 600;">✓ Approved on
                                        @Model.Approval.ApprovedAt?.ToSydneyString()</span>
                                    }
                                else
                                    {
                                        <span>Pending (@(Model.Approval.ChecklistItemsCompleted)/4 items checked)</span>
                                        <div class="progress" style="height: 20px; margin-top: 10px;">
                                            <div class="progress-bar" style="width: @(Model.Approval.ChecklistItemsCompleted * 25)%"></div>
                                        </div>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Approval.ChangesRequired))
                                {
                                    <div style="margin-top: 10px; padding-top: 10px; border-top: 1px solid #ddd;">
                                        <strong>Changes Required:</strong><br />
                                        @Model.Approval.ChangesRequired
                                    </div>
                                }
                            </div>
                        }
                    }
                </section>

                <section class="details-card wide-card">
                    <h2>Update Job</h2>
                    <div class="update-job-layout">
                        <form method="post" asp-page-handler="Update" class="update-form">
                            <label>
                                Status
                                <select asp-for="UpdateInput.Status">
                                    @foreach (var status in JobStatus.All)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </label>

                            <label>
                                Notes
                                <textarea asp-for="UpdateInput.Notes"></textarea>
                            </label>

                            <button class="primary-button" type="submit">Save Changes</button>
                        </form>

                        <form method="post" asp-page-handler="AddNote" class="notes-form">
                            <label>
                                Add Note
                                <textarea asp-for="NewNote" placeholder="Add a timestamped note..."></textarea>
                            </label>
                            <label>
                                Your Name
                                <input type="text" asp-for="NoteAddedBy" placeholder="Enter your name" />
                            </label>
                            <button class="primary-button" type="submit">Add Note</button>
                        </form>

                        <div id="editNoteForm"
                             style="display: none; background: #f9f9f9; padding: 15px; border-radius: 8px; margin-top: 15px; border-left: 4px solid #ed1c24;">
                            <h4>Edit Note</h4>
                            <form method="post" asp-page-handler="EditNote">
                                <input type="hidden" id="editNoteId" name="EditNoteId" />
                                <label>
                                    Note Content
                                    <textarea id="editNoteContent" name="EditNoteContent" required
                                              style="width: 100%; min-height: 100px; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-family: 'Roboto', sans-serif;"></textarea>
                                </label>
                                <div style="display: flex; gap: 10px; margin-top: 10px;">
                                    <button type="submit" class="primary-button" style="padding: 8px 16px; font-size: 14px;">Save
                                        Changes</button>
                                        <button type="button" onclick="cancelEditNote()" class="secondary-button"
                                                style="padding: 8px 16px; font-size: 14px;">Cancel</button>
                                    </div>
                                </form>
                            </div>

                            <script>
                                            function editNote(noteId, content) {
                                                document.getElementById('editNoteId').value = noteId;
                                                document.getElementById('editNoteContent').value = content;
                                                document.getElementById('editNoteForm').style.display = 'block';
                                                document.getElementById('editNoteContent').focus();
                                            }

                                            function cancelEditNote() {
                                                document.getElementById('editNoteForm').style.display = 'none';
                                                document.getElementById('editNoteId').value = '';
                                                document.getElementById('editNoteContent').value = '';
                                            }
                            </script>

                            @if (Model.Job.JobNotes.Any())
                            {
                                <aside class="notes-sidebar">
                                    <h3>Notes</h3>
                                    @foreach (var note in Model.Job.JobNotes)
                                    {
                                        <div class="note-item">
                                            <p class="note-content">@note.Content</p>
                                            <span class="note-author">by @note.AddedBy</span>
                                            <span class="note-date">@note.CreatedAt.ToSydneyString()</span>
                                            @if (HttpContext.Session.GetString("Role") == "Admin")
                                            {
                                                <div class="note-actions" style="margin-top: 8px; display: flex; gap: 8px;">
                                                    <button type="button" class="note-edit-btn"
                                                            onclick="editNote(@note.Id, '@Html.Raw(note.Content.Replace("'", "&#39;"))')">Edit</button>
                                                    <form method="post" asp-page-handler="DeleteNote" style="display: inline; margin: 0;"
                                                          onsubmit="return confirm('Delete this note?');">
                                                        <input type="hidden" name="noteId" value="@note.Id" />
                                                        <button type="submit" class="note-delete-btn">Delete</button>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                    }
                                </aside>
                            }
                        </div>
                    </section>

                    @if (HttpContext.Session.GetString("Role") == "Admin")
                    {
                        <section class="details-card">
                            <h2>Danger Zone</h2>
                            <p style="color: #dc3545; margin-bottom: 15px;"><strong>Warning:</strong> Deleting a job will permanently remove
                                it and all associated approvals and notes. This action cannot be undone.</p>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Job.Id" class="mini-form"
                                      onsubmit="return confirm('Are you sure you want to delete this job? This action cannot be undone.');">
                                    <button type="submit" class="danger-button" style="display: flex; align-items: center; gap: 6px;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                        Delete Job
                                    </button>
                                </form>
                            </section>
                        }
                    </div>
                }

<!-- PDF.js Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
    // Set up PDF.js worker
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    @if (Model.Job.HasPdf)
    {
        <text>
        async function renderPdf() {
            try {
                const pdfPath = '@Html.Raw(Model.Job.DraftPdfPath)';
                const pdf = await pdfjsLib.getDocument(pdfPath).promise;
                const page = await pdf.getPage(1);
                
                const canvas = document.getElementById('pdfCanvas');
                const context = canvas.getContext('2d');
                
                // Set canvas size to fit page
                const viewport = page.getViewport({ scale: 1.5 });
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                
                // Render page
                await page.render({
                    canvasContext: context,
                    viewport: viewport
                }).promise;
                
                // Hide loading message
                const loading = document.getElementById('pdfLoading');
                if (loading) loading.style.display = 'none';
            } catch (error) {
                console.error('Error rendering PDF:', error);
                const loading = document.getElementById('pdfLoading');
                if (loading) {
                    loading.textContent = 'Error loading PDF. Use "Open PDF" button above.';
                    loading.style.color = '#dc3545';
                }
            }
        }
        
        // Render when page loads
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', renderPdf);
        } else {
            renderPdf();
        }
        </text>
    }
</script>
