@page "{id:int}"
@model FireStopEvacTracker.Pages.Jobs.DetailsModel
@{
    ViewData["Title"] = "Job Details";
}

@if (Model.Job is not null)
{
    <div class="page-header">
        <div>
            <h1>@Model.Job.GetShortJobName()</h1>
            <p>@Model.Job.ClientName — @Model.Job.SiteAddress</p>
        </div>
        <a class="secondary-button" href="/Jobs">Back to Jobs</a>
    </div>

    <div class="details-grid">
        <!-- Compact Job Overview Grid -->
        <section class="details-card" style="padding: 16px;">
            <div class="job-overview-grid">
                <div class="overview-item">
                    <span class="overview-item-label">Date Started</span>
                    <span class="overview-item-value">@Model.Job.DateStarted.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="overview-item">
                    <span class="overview-item-label">Client</span>
                    <span class="overview-item-value">@Model.Job.ClientName</span>
                </div>
                <div class="overview-item">
                    <span class="overview-item-label">Status</span>
                    <span class="overview-item-value">
                        <span class="status-pill status-@Model.Job.Status.ToLower().Replace(" ", "-")">@Model.Job.Status</span>
                    </span>
                </div>
                <div class="overview-item">
                    <span class="overview-item-label">Location</span>
                    <span class="overview-item-value" style="font-size: 12px;">@Model.Job.SiteAddress</span>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Job.Notes))
            {
                <div style="background: #f9f9f9; padding: 10px; border-radius: 6px; border-left: 3px solid #ed1c24; margin-top: 8px; font-size: 13px;">
                    <strong style="display: block; margin-bottom: 4px; color: #555;">Notes</strong>
                    @Model.Job.Notes
                </div>
            }
            @if (Model.Job.StatusUpdatedAt.HasValue)
            {
                <div style="text-align: right; margin-top: 8px; font-size: 11px; color: #999;">
                    Updated: @Model.Job.StatusUpdatedAt.Value.ToSydneyString()
                </div>
            }
        </section>

        <!-- PDF and Documents Side by Side -->
        <div class="deliverables-grid">
            <section class="details-card">
            <h2 style="margin-top: 0; font-size: 16px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                <svg class="icon-inline" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
                Draft PDF
            </h2>

            @if (Model.Job.HasPdf)
            {
                <p style="margin: 0 0 10px 0; font-weight: 500; color: #333; font-size: 12px;">
                    <strong>@Model.Job.DraftPdfFileName</strong>
                </p>
                
                <!-- PDF Preview -->
                <div style="border: 1px solid #ddd; border-radius: 6px; overflow: hidden; margin-bottom: 10px; background: #f9f9f9;">
                    <embed src="@Model.Job.DraftPdfPath" type="application/pdf" style="width: 100%; height: 400px;" />
                </div>
                
                <div style="display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap;">
                    <a class="primary-button" href="@Model.Job.DraftPdfPath" target="_blank" style="padding: 8px 12px; font-size: 12px; display: flex; align-items: center; gap: 6px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        View PDF
                    </a>
                    
                    @{
                        string emailSubject = $"Evac Review - {Model.Job.ClientName} {Model.Job.JobName}";
                        string emailBody = $"Hi {Model.Job.ClientName},%0A%0AThe attached evacuation diagram drawings are ready for your review.%0A%0APlease find the PDF attached.%0A%0AJob: {Model.Job.JobName}%0AClient: {Model.Job.ClientName}%0AAddress: {Model.Job.SiteAddress}%0A%0APlease let me know if you have any questions or require any modifications.%0A%0ABest regards,";
                        string mailtoLink = $"mailto:?subject={Uri.EscapeDataString(emailSubject)}&body={emailBody}";
                    }
                    <a href="@mailtoLink" class="primary-button" style="padding: 8px 12px; font-size: 12px; display: flex; align-items: center; gap: 6px;" title="Open in email client">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg>
                        Email
                    </a>
                    <a href="@Model.Job.DraftPdfPath" download="@Model.Job.DraftPdfFileName" class="secondary-button" style="padding: 8px 12px; font-size: 12px; display: flex; align-items: center; gap: 6px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download
                    </a>
                </div>
            }
            else
            {
                <p style="color: #999; font-size: 13px; margin: 0 0 10px 0;">No draft PDF attached.</p>
            }

            <form method="post" enctype="multipart/form-data" asp-page-handler="ReplacePdf" style="display: grid; grid-template-columns: 1fr auto auto; gap: 8px; align-items: flex-end;">
                <input type="file" asp-for="NewDraftPdf" accept="application/pdf" style="padding: 6px; font-size: 12px;" />
                <button type="submit" style="padding: 6px 12px; font-size: 12px; white-space: nowrap;">Attach PDF</button>
                @if (Model.Job.HasPdf)
                {
                    <button type="button" class="danger-button" style="padding: 6px 12px; font-size: 12px;" onclick="if(confirm('Remove PDF?')) { document.querySelector('form[asp-page-handler=RemovePdf]').submit(); }">Remove</button>
                }
            </form>
        </section>

        <section class="details-card">
            <h2 style="margin-top: 0; font-size: 16px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.13 17.9l5.77-5.77M6.21 17.82L17 7m-10 0l10 10"></path><path d="M9 13a3 3 0 1 1 4.24-4.24"></path></svg>
                Related Documents
            </h2>

            @if (Model.Job.JobDocuments.Any())
            {
                <div class="document-table-wrapper">
                    <table class="document-table">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Type</th>
                                <th>File</th>
                                <th style="width: 140px;">Uploaded</th>
                                <th style="width: 70px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model.Job.JobDocuments)
                            {
                                <tr>
                                    <td>
                                        <span class="doc-type-badge">@doc.DocumentType</span>
                                    </td>
                                    <td>
                                        <a href="@doc.DocumentPath" target="_blank" class="doc-file-link" title="@doc.FileName">
                                            @(doc.FileName.Length > 30 ? doc.FileName.Substring(0, 30) + "..." : doc.FileName)
                                        </a>
                                    </td>
                                    <td class="doc-meta">
                                        @doc.UploadedAt.ToSydneyString()
                                        @if (!string.IsNullOrEmpty(doc.UploadedBy))
                                        {
                                            <br /><span style="font-size: 10px;">by @doc.UploadedBy</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="doc-actions-cell">
                                            <a href="@doc.DocumentPath" download class="doc-action-btn" title="Download document">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                            </a>
                                            @{
                                                var userRole = HttpContext.Session.GetString("Role");
                                                if (userRole == "Admin")
                                                {
                                                    <form method="post" asp-page-handler="DeleteDocument" asp-route-documentId="@doc.Id" style="display: inline; margin: 0;">
                                                        <button type="submit" class="doc-action-btn delete" onclick="return confirm('Delete this document?');" title="Delete document">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                                    </button>
                                                    </form>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p style="color: #999; font-size: 13px; margin: 0 0 10px 0;">No documents uploaded.</p>
            }

            <form method="post" enctype="multipart/form-data" asp-page-handler="UploadDocument" class="doc-upload-compact">
                <div class="doc-upload-compact-row">
                    <input type="text" asp-for="DocumentType" placeholder="Invoice, Spec, etc." />
                    <input type="text" asp-for="DocumentUploadedBy" placeholder="Your name (optional)" />
                    <input type="file" asp-for="RelatedDocument" style="padding: 6px; font-size: 11px;" />
                    <button type="submit" style="margin: 0;">📤 Upload</button>
                </div>
            </form>
        </section>
    </div>

    <!-- Client Approval Section -->
    <section class="details-card">
    <!-- Client Approval Section -->
    <section class="details-card">
        <h2 style="margin-top: 0; font-size: 16px; margin-bottom: 12px;">👥 Client Approval</h2>
                
        @if (string.IsNullOrEmpty(Model.Job.ShareCode))
        {
            <p style="font-size: 13px; margin: 0 0 10px 0; color: #666;">Generate a shareable link for client approval.</p>
            <form method="post" asp-page-handler="GenerateShareCode" style="display: inline;">
                <button type="submit" class="primary-button" style="padding: 8px 16px; font-size: 12px; display: flex; align-items: center; gap: 6px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Generate Link
            </button>
            </form>
        }
        else
        {
            <div class="approval-info">
                <strong>Share Link Generated</strong>
                <div style="display: flex; gap: 8px; align-items: stretch; margin-top: 8px;">
                    <input type="text" id="shareLink" readonly style="flex: 1; padding: 8px; background: white; border: 1px solid #999; border-radius: 4px; font-family: monospace; font-size: 11px;" value="@Html.Raw($"{Request.Scheme}://{Request.Host}/JobApprove/{Model.Job.ShareCode}")" />
                    <button type="button" id="copyBtn" onclick="copyShareLink()" title="Copy link to clipboard" style="background: white; border: 1px solid #999; color: #333; padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 12px; white-space: nowrap; display: flex; align-items: center; gap: 6px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                        Copy
                    </button>
                </div>
            </div>

            <script>
                function copyShareLink() {
                    const shareLink = document.getElementById('shareLink');
                    const btn = document.getElementById('copyBtn');
                    
                    if (navigator.clipboard && window.isSecureContext) {
                        navigator.clipboard.writeText(shareLink.value).then(() => {
                            showSuccess(btn);
                        }).catch(err => {
                            fallbackCopy(shareLink, btn);
                        });
                    } else {
                        fallbackCopy(shareLink, btn);
                    }
                    
                    function fallbackCopy(element, button) {
                        try {
                            element.select();
                            element.setSelectionRange(0, 99999);
                            const successful = document.execCommand('copy');
                            if (successful) {
                                showSuccess(button);
                            } else {
                                alert('Please manually copy the link');
                            }
                        } catch (err) {
                            alert('Unable to copy. Please manually select and copy.');
                        }
                    }
                    
                    function showSuccess(button) {
                        const originalText = button.textContent;
                        button.textContent = '✓ Copied!';
                        button.style.background = '#d4edda';
                        button.style.borderColor = '#28a745';
                        button.style.color = '#155724';
                        
                        setTimeout(() => {
                            button.textContent = originalText;
                            button.style.background = 'white';
                            button.style.borderColor = '#999';
                            button.style.color = '#333';
                        }, 1500);
                    }
                }
            </script>

            @if (Model.Approval != null)
            {
                <div style="background: linear-gradient(135deg, #f0fff4 0%, #e8f5e9 100%); padding: 10px; border-radius: 6px; border-left: 3px solid #28a745; margin-top: 10px; font-size: 12px;">
                    <strong>Approval Status:</strong><br />
                    @if (Model.Approval.IsApproved)
                    {
                        <span class="approval-status">✓ Approved @Model.Approval.ApprovedAt?.ToSydneyString()</span>
                    }
                    else
                    {
                        <span>Pending (@(Model.Approval.ChecklistItemsCompleted)/4 items checked)</span>
                        <div style="background: white; height: 4px; border-radius: 2px; margin-top: 6px; overflow: hidden;">
                            <div style="height: 100%; background: #28a745; width: @(Model.Approval.ChecklistItemsCompleted * 25)%;"></div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Approval.ChangesRequired))
                    {
                        <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(0,0,0,0.1);">
                            <strong>Changes Needed:</strong><br />
                            <span style="color: #666;">@Model.Approval.ChangesRequired</span>
                        </div>
                    }
                </div>
            }
        }
    </section>

    <!-- Update Job Section with Tabs -->
    <section class="details-card" style="padding: 0;">
        <div class="tabs-wrapper">
            <div class="tab-buttons" style="padding: 0 16px;">
                <button class="tab-btn active" onclick="switchTab(event, 'update-status')" style="display: flex; align-items: center; gap: 6px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="3" x2="16" y2="21"></line><line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line></svg>
                    Status & Notes
                </button>
                <button class="tab-btn" onclick="switchTab(event, 'add-note')" style="display: flex; align-items: center; gap: 6px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    Add Note
                </button>
                @if (Model.Job.JobNotes.Any())
                {
                    <button class="tab-btn" onclick="switchTab(event, 'view-notes')" style="display: flex; align-items: center; gap: 6px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        History (@Model.Job.JobNotes.Count)
                    </button>
                }
            </div>

            <div class="tab-content-wrapper">
                <!-- Tab 1: Update Status & Notes -->
                <div id="update-status" class="tab-pane active">
                    <form method="post" asp-page-handler="Update" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                        <div>
                            <label style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px;">Status</label>
                            <select asp-for="UpdateInput.Status" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px;">
                                @foreach (var status in JobStatus.All)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </div>
                        <div style="display: flex; align-items: flex-end;">
                            <button class="primary-button" type="submit" style="width: 100%; padding: 8px; font-size: 13px; display: flex; align-items: center; justify-content: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                            Save Status
                        </button>
                        </div>
                    </form>
                    <div style="margin-top: 16px;">
                        <label style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px;">Job Notes</label>
                        <textarea asp-for="UpdateInput.Notes" style="width: 100%; min-height: 100px; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; font-family: 'Roboto', sans-serif;"></textarea>
                        <button class="primary-button" type="submit" onclick="document.querySelector('form[asp-page-handler=Update]').submit();" style="margin-top: 8px; padding: 8px 16px; font-size: 13px; display: flex; align-items: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                            Save Notes
                        </button>
                    </div>
                </div>

                <!-- Tab 2: Add Note -->
                <div id="add-note" class="tab-pane">
                    <form method="post" asp-page-handler="AddNote" style="display: grid; gap: 12px;">
                        <div>
                            <label style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px;">New Note</label>
                            <textarea asp-for="NewNote" placeholder="Add a timestamped note..." style="width: 100%; min-height: 80px; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; font-family: 'Roboto', sans-serif;"></textarea>
                        </div>
                        <div>
                            <label style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px;">Your Name</label>
                            <input type="text" asp-for="NoteAddedBy" placeholder="Enter your name" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px;" />
                        </div>
                        <button class="primary-button" type="submit" style="padding: 8px 16px; font-size: 13px; display: flex; align-items: center; gap: 6px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            Add Note
                        </button>
                    </form>
                </div>

                <!-- Tab 3: View Notes History -->
                @if (Model.Job.JobNotes.Any())
                {
                    <div id="view-notes" class="tab-pane">
                        <div style="display: grid; gap: 10px;">
                            @foreach (var note in Model.Job.JobNotes)
                            {
                                <div class="note-item">
                                    <p class="note-content">@note.Content</p>
                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <div>
                                            <span class="note-author">@note.AddedBy</span>
                                            <span class="note-date">@note.CreatedAt.ToSydneyString()</span>
                                        </div>
                                        @if (HttpContext.Session.GetString("Role") == "Admin")
                                        {
                                            <div style="display: flex; gap: 6px;">
                                                <button type="button" class="note-edit-btn" onclick="editNote(@note.Id, '@Html.Raw(note.Content.Replace("'", "&#39;"))')">Edit</button>
                                                <form method="post" asp-page-handler="DeleteNote" style="display: inline; margin: 0;"
                                                      onsubmit="return confirm('Delete this note?');">
                                                    <input type="hidden" name="noteId" value="@note.Id" />
                                                    <button type="submit" class="note-delete-btn">Delete</button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div id="editNoteForm" style="display: none; background: linear-gradient(to right, #fff3f0, #ffebee); padding: 12px; border-radius: 6px; border-left: 3px solid #ed1c24; margin-top: 12px;">
                    <h4 style="margin: 0 0 10px 0; font-size: 13px;">Edit Note</h4>
                    <form method="post" asp-page-handler="EditNote">
                        <input type="hidden" id="editNoteId" name="EditNoteId" />
                        <textarea id="editNoteContent" name="EditNoteContent" required style="width: 100%; min-height: 80px; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-family: 'Roboto', sans-serif; font-size: 13px;"></textarea>
                        <div style="display: flex; gap: 8px; margin-top: 8px;">
                            <button type="submit" class="primary-button" style="padding: 6px 12px; font-size: 12px;">Save</button>
                            <button type="button" onclick="cancelEditNote()" class="secondary-button" style="padding: 6px 12px; font-size: 12px;">Cancel</button>
                        </div>
                    </form>
                </div>

                <script>
                    function switchTab(event, tabId) {
                        event.preventDefault();
                        
                        // Hide all tabs
                        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
                        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
                        
                        // Show selected tab
                        document.getElementById(tabId).classList.add('active');
                        event.target.classList.add('active');
                    }
                    
                    function editNote(noteId, content) {
                        document.getElementById('editNoteId').value = noteId;
                        document.getElementById('editNoteContent').value = content;
                        document.getElementById('editNoteForm').style.display = 'block';
                        document.getElementById('editNoteContent').focus();
                    }

                    function cancelEditNote() {
                        document.getElementById('editNoteForm').style.display = 'none';
                        document.getElementById('editNoteId').value = '';
                        document.getElementById('editNoteContent').value = '';
                    }
                </script>
            </div>
        </div>
    </section>

    <!-- Danger Zone -->
    @if (HttpContext.Session.GetString("Role") == "Admin")
    {
        <section class="details-card danger-section">
